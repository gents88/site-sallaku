<div style="background:#0f1831;border-radius:10px;border:1px solid {{accent}}33;overflow:hidden;">
  <div style="background:{{accent}}1f;padding:10px 16px;border-bottom:1px solid {{accent}}26;">
    <span style="color:{{accent}};font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;">{{icon}} {{title}}</span>
  </div>
  <table role="presentation" style="width:100%;border-collapse:collapse;">
    {{#each rows}}
    <tr style="{{#if zebra}}background:rgba(255,255,255,0.02);{{/if}}">
      {{#if rank}}
      <td style="padding:7px 0 7px 16px;color:#64748b;font-size:0.8rem;width:24px;">{{rank}}</td>
      {{/if}}
      <td style="padding:7px 16px;color:#e2e8f0;font-size:0.85rem;word-break:break-word;">{{label}}</td>
      <td style="padding:7px 16px 7px 0;width:45%;">
        <table role="presentation" style="width:100%;border-collapse:collapse;">
          <tr>
            <td style="vertical-align:middle;">
              <div style="background:{{../accent}}26;border-radius:3px;height:6px;">
                <div style="background:{{../accent}};height:6px;border-radius:3px;width:{{barWidth}}%;font-size:0;line-height:0;">&nbsp;</div>
              </div>
            </td>
            <td style="vertical-align:middle;width:44px;text-align:right;color:#94a3b8;font-size:0.82rem;padding-left:8px;">{{count}}</td>
          </tr>
        </table>
      </td>
    </tr>
    {{else}}
    <tr><td style="padding:12px 16px;color:#475569;font-size:0.83rem;text-align:center;">{{emptyText}}</td></tr>
    {{/each}}
  </table>
</div>
