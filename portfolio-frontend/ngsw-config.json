{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/favicon.svg",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "static-assets",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/i18n/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "blog-list-api",
      "urls": [
        "https://portfolio-backend-production-e76d.up.railway.app/api/v1/blog/posts*"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 30,
        "maxAge": "5m",
        "timeout": "3s"
      }
    },
    {
      "name": "blog-detail-api",
      "urls": [
        "https://portfolio-backend-production-e76d.up.railway.app/api/v1/blog/posts/*"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 50,
        "maxAge": "20m",
        "timeout": "3s"
      }
    },
    {
      "name": "static-api",
      "urls": [
        "https://portfolio-backend-production-e76d.up.railway.app/api/v1/projects*",
        "https://portfolio-backend-production-e76d.up.railway.app/api/v1/about*",
        "https://portfolio-backend-production-e76d.up.railway.app/api/v1/experiences*"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 10,
        "maxAge": "1h",
        "timeout": "5s"
      }
    }
  ]
}